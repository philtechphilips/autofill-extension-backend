# Environment (development | production)
NODE_ENV=development

# Server port (default 3000). Use 9000 to match extension default.
PORT=9000

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:3000

# MongoDB connection URL (required)
DB_URL=mongodb://localhost:27017/autofillai

# DeepSeek API key (required) – https://platform.deepseek.com
DEEPSEEK_API_KEY=

# AI Configuration (optional)
AI_BASE_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat

# JWT Configuration (required in production)
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-access-token-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Resend)
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=Autofill.AI <noreply@yourdomain.com>
EMAIL_REPLY_TO=support@yourdomain.com

# CORS (optional, default allows all origins)
CORS_ORIGIN=*
